# ============================================================
# .gitignore — LoL Nexus (Vite + React + TypeScript)
# ============================================================

# --- Dependencies ---
node_modules/
.pnpm-store/
.yarn/

# --- Build Outputs ---
dist/
build/
.vite/
.parcel-cache/
.turbo/
.vercel/
.next/

# --- Environment Variables & Secrets ---
.env
.env.local
.env.*.local
*.pem
secrets.yml
.netrc

# --- OS / System Files ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# --- IDEs & Editors ---
.vscode/
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
.idea/
*.iws
*.iml
*.ipr
*.sublime-project
*.sublime-workspace
*.swp
*.swo

# --- Logs ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm/
.eslintcache
.stylelintcache

# --- Test & QA Artifacts ---
coverage/
.nyc_output/
# One-off QA scripts and debug files at project root
qa_scaling*.mjs
qa_scaling.ts
qa_scaling_debug*.mjs
qa_scaling_links.js
debug-console.spec.ts
test-meraki.spec.ts
fetchItems.js

# --- Playwright Screenshots (not source-controlled) ---
*.png
!public/**/*.png

# --- Agent & Tooling ---
.agent/temp/
.agent/cache/
.agent/skills/playwright-skill/.temp-*.js
# Keep .agent/skills — these are part of the project's dev toolchain

# --- TypeScript Build Info ---
*.tsbuildinfo
tsconfig.node.tsbuildinfo